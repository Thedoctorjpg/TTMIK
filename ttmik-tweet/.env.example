# TTMIK Tweet — Environment Variables
# Copy to .env and fill in your values

# Webhook URL for automated X posting (proxied to shopify-twitter in dev)
VITE_TTMIK_WEBHOOK_URL=/api/ttmik-webhook

# Target X profile for tweet output
VITE_X_HANDLE=adhdloganberry

# X (Twitter) API — for automated tweet posting from webhook
TWITTER_BEARER_TOKEN=

# Shopify Admin API — for progress metafield tracking
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
