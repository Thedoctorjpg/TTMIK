# TTMIK Tweet — Environment Variables
# Copy to .env and fill in your values

# Webhook URL for Shopify + X integration (optional)
# Point this at your deployed webhook endpoint
VITE_TTMIK_WEBHOOK_URL=https://your-project.vercel.app/api/ttmik-webhook

# X (Twitter) API — for automated tweet posting from webhook
TWITTER_BEARER_TOKEN=

# Shopify Admin API — for progress metafield tracking
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
